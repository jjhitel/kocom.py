{
    "name": "Kocom Wallpad with RS485",
    "version": "2023.06.11-5",
    "slug": "kocom_py",
    "description": "Kocom Wallpad for Home Assistant",
    "arch": [
        "armhf",
        "armv7",
        "aarch64",
        "amd64",
        "i386"
    ],
    "url": "https://github.com/jjhitel/kocom.py",
    "startup": "application",
    "boot": "auto",
    "uart": true,
    "map": [
        "share:rw"
    ],
    "options": {
        "RS485": {
            "type": "socket",
            "socket_server": "192.168.x.x",
            "socket_port": 8899
        },
        "MQTT": {
            "mqtt_allow_anonymous": false,
            "mqtt_server": "192.168.x.x",
            "mqtt_port": 1883,
            "mqtt_username": "id",
            "mqtt_password": "pw"
        },
        "Device":    {
            "enabled": "light, gas, thermo_livingroom, thermo_bedroom, thermo_room1, thermo_room2, plug, elevator, fan"
        },
        "Elevator": {
            "type": "rs485",
            "rs485_floor": 15
        },
        "Log": {
            "show_query_hex": true,
            "show_recv_hex": true,
            "show_mqtt_discovery": true,
            "show_mqtt_publish": true
        },
        "User": {
            "init_temp": 23,
            "init_fan_mode": "Medium",
            "light_count": 2
        }
    },
    "schema": {
        "RS485": {
            "type": "list(serial|socket)",
            "socket_server": "str?",
            "serial_port": "int?",
            "socket_port": "int?"
        },
        "MQTT": {
            "mqtt_server": "str",
            "mqtt_port": "int?",
            "mqtt_allow_anonymous": "bool",
            "mqtt_username": "str",
            "mqtt_password": "str"
        },
        "Device": {
            "enabled": "str"
        },
        "Elevator": {
            "type": "list(rs485|tcpip)",
            "rs485_floor": "int?"
        },
        "Log": {
            "show_query_hex": "bool?",
            "show_recv_hex": "bool?",
            "show_mqtt_discovery": "bool?",
            "show_mqtt_publish": "bool?"
        },
        "User": {
            "init_temp": "int(10,30)",
            "init_fan_mode" : "list(Low|Medium|High)",
            "light_count" : "int"
        }
    }
}
